---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import CopyCodeButton from '../components/CopyCodeButton.astro';
import Footer from '../components/Footer.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface NavItem {
  title: string;
  slug: string;
}

interface Props {
  title: string;
  description?: string;
  currentSlug: string;
  headings: Heading[];
  prev?: NavItem | null;
  next?: NavItem | null;
  editUrl?: string;
}

const { title, description, currentSlug, headings, prev, next, editUrl } =
  Astro.props;
---

<BaseLayout title={`${title} — Ion`} description={description}>
  <Header showMenuButton={true} />
  <Sidebar currentSlug={currentSlug} />

  <div class="docs-layout">
    <main class="docs-main">
      <article class="prose animate-fade-in" data-pagefind-body>
        <slot />
      </article>

      {editUrl && (
        <div class="edit-link-wrapper">
          <a href={editUrl} class="edit-link" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            Edit this page on GitHub
          </a>
        </div>
      )}

      <PrevNextNav prev={prev} next={next} />

      <div class="docs-footer">
        <Footer />
      </div>
    </main>
  </div>

  <TableOfContents headings={headings} />
  <CopyCodeButton />
</BaseLayout>

<style>
  .docs-layout {
    margin-top: var(--header-height);
    margin-left: var(--sidebar-width);
    margin-right: var(--toc-width);
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
  }

  .docs-main {
    flex: 1;
    max-width: calc(var(--content-max-width) + 4rem);
    width: 100%;
    margin: 0 auto;
    padding: 2.5rem 2rem 0;
  }

  .docs-footer {
    margin-top: auto;
  }

  .edit-link-wrapper {
    display: flex;
    justify-content: flex-end;
    margin-top: 2.5rem;
  }

  .edit-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    color: var(--text-tertiary);
    transition: color var(--transition-fast);
  }

  .edit-link:hover {
    color: var(--accent);
  }

  @media (min-width: 1440px) {
    .docs-main {
      max-width: calc(var(--content-max-width) + var(--code-extra) + 4rem);
    }
  }

  @media (max-width: 1279px) {
    .docs-layout {
      margin-right: 0;
    }
  }

  @media (max-width: 1023px) {
    .docs-layout {
      margin-left: 0;
    }

    .docs-main {
      padding: 2rem 1.25rem 0;
    }
  }
</style>
